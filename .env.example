# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Backend auth allowlist
# Prefer user IDs where possible. Emails are easier to start with but can change.
ALLOWED_USER_IDS=00000000-0000-0000-0000-000000000000
# ALLOWED_USER_EMAILS=you@example.com,burton@example.com
# ALLOW_ANY_AUTHENTICATED_USER=true # Development only; do not use in production.

# Gmail ingest
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-refresh-token
GMAIL_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Slab Intake / PSA cert lookup
PSA_API_TOKEN=your-psa-api-token
# PSA_API_KEY=your-psa-api-key
