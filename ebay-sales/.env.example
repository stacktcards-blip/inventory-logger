# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# eBay API (required for sync)
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_REFRESH_TOKEN=your-ebay-refresh-token
EBAY_ENVIRONMENT=production

# eBay OAuth flow (for generating refresh token – see /oauth page)
NEXT_PUBLIC_EBAY_APP_ID=your-ebay-app-id
# RuName string from eBay User Tokens (e.g. James_James-YourApp-PRD-xxxxx), NOT a URL
NEXT_PUBLIC_EBAY_RUNAME=your-runame-string

# Cron protection (required for POST /api/jobs/sync-ebay)
CRON_SECRET=your-random-secret-for-cron-calls

# CORS (optional – defaults to http://localhost:3003 for dev)
# CORS_ORIGIN=http://localhost:3003
