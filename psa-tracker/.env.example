# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron protection (required for POST /api/sync/all – MVP; Phase 2 uses Edge Function)
CRON_SECRET=your-random-secret-for-cron-calls

# PSA API (optional – mock provider used if not set)
# Get token: https://api.psacard.com/publicapi/documentation
# PSA_API_TOKEN=
# PSA_USE_MOCK=true   # Force mock provider when real API isn't working

# DHL Shipment Tracking (Phase 2 – get key from developer.dhl.com)
# DHL_API_KEY=

# Telegram (Phase 2)
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# App base URL for deep links in Telegram (dev: localhost:3001)
APP_BASE_URL=http://localhost:3001

# Slabs Inventory UI base URL for "View in Slabs" links (Phase 3)
# NEXT_PUBLIC_SLABS_INVENTORY_URL=http://localhost:5173

# Orders NEW (Gmail): scrape PSA emails for orders, billing, shipped
# OAuth2: create app at console.cloud.google.com, enable Gmail API, get refresh token via OAuth Playground
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# Show "Orders NEW" tab (default: true in development)
# NEXT_PUBLIC_PSA_ORDERS_NEW_TAB=true
